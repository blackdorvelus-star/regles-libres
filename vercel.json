{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "success.html", "use": "@vercel/static" },
    { "src": "cancel.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/cancel", "dest": "/cancel.html" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
